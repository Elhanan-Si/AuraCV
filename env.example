# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION - AURACV (RESUME BUILDER)
# ==============================================================================
# Copy this file to a new file named '.env' at the root of the project before running.
# e.g., cp .env.example .env
#
# Since this project is a monorepo, these values are used by both the client and server.

# ------------------------------------------------------------------------------
# Backend Service Configuration (Express & Puppeteer)
# ------------------------------------------------------------------------------

# The port where the backend API (PDF generation service) will listen.
# Default: 3001
PORT=3001

# The Node environment configuration (development, production, test)
# Default: development
NODE_ENV=development

# Puppeteer Chromium launch options (uncomment if running in custom environments like Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ------------------------------------------------------------------------------
# Frontend Client Configuration (Vite & React)
# ------------------------------------------------------------------------------

# The port where the client-side Vite server will run in development mode.
# Default: 5173
VITE_PORT=5173

# The public backend API base URL. Vite proxies local `/api` calls during development,
# but for production deployments, you can configure your server/proxy or set this
# if the frontend and backend are hosted on separate domains.
# Default: http://localhost:3001
VITE_API_URL=http://localhost:3001
